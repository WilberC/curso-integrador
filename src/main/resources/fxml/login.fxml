<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1024.0" styleClass="app-shell" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.plazavea.perecibles.controller.LoginController">
    <center>
        <VBox alignment="CENTER" maxWidth="420.0" spacing="16.0" styleClass="login-panel">
            <Label styleClass="wordmark" text="Plaza Vea" />
            <Label styleClass="screen-title" text="Control de Perecibles" />
            <Label fx:id="userLabel" styleClass="muted" />

            <VBox spacing="8.0">
                <Label styleClass="field-label" text="Usuario" />
                <TextField promptText="supervisor@plazavea.pe" styleClass="text-input" />
            </VBox>

            <VBox spacing="8.0">
                <Label styleClass="field-label" text="Contrasena" />
                <PasswordField promptText="********" styleClass="text-input" />
            </VBox>

            <Button defaultButton="true" maxWidth="Infinity" mnemonicParsing="true" styleClass="button-primary" text="_Ingresar" />
            <Button cancelButton="true" maxWidth="Infinity" mnemonicParsing="true" styleClass="button-secondary" text="Usar datos _simulados" />
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="24.0" styleClass="shortcut-bar">
            <HBox alignment="CENTER_LEFT">
                <Label styleClass="shortcut-key" text="Enter" />
                <Label styleClass="shortcut-desc" text="Ingresar" />
            </HBox>
            <HBox alignment="CENTER_LEFT">
                <Label styleClass="shortcut-key" text="Tab" />
                <Label styleClass="shortcut-desc" text="Mover foco" />
            </HBox>
            <HBox alignment="CENTER_LEFT">
                <Label styleClass="shortcut-key" text="Esc" />
                <Label styleClass="shortcut-desc" text="Datos simulados" />
            </HBox>
        </HBox>
    </bottom>
</BorderPane>
