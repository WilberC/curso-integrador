<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1024.0" styleClass="app-shell" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.plazavea.perecibles.controller.LoginController">
    <center>
        <VBox alignment="CENTER" maxWidth="420.0" spacing="18.0" styleClass="card">
            <padding>
                <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
            </padding>

            <Label styleClass="wordmark" text="Plaza Vea" />
            <Label styleClass="screen-title" text="Control de Perecibles" />
            <Label fx:id="userLabel" styleClass="muted" />

            <VBox spacing="10.0">
                <Label styleClass="field-label" text="Usuario" />
                <TextField promptText="supervisor@plazavea.pe" styleClass="text-input" />
            </VBox>

            <VBox spacing="10.0">
                <Label styleClass="field-label" text="Contrasena" />
                <PasswordField promptText="********" styleClass="text-input" />
            </VBox>

            <Button maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-primary" text="Ingresar" />
            <Button maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-secondary" text="Usar datos simulados" />
        </VBox>
    </center>
</BorderPane>
